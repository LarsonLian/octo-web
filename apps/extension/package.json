{
  "name": "Octo Extension",
  "description": "Octo Extension",
  "private": true,
  "version": "0.0.0.1",
  "type": "module",
  "scripts": {
    "dev": "wxt --port 5678",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
